{
  "name": "my-portfolio",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,vue,scss,json}\" \"*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,scss,json}\" \"*.{ts,js,json,md}\""
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "vuetify": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^9.36.0",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.0",
    "sass": "^1.71.0",
    "typescript": "~5.9.0",
    "vite": "^8.0.0",
    "vite-plugin-vuetify": "^2.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.0"
  }
